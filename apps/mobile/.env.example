# Mobile (Expo) env. Copy to .env.
# EXPO_PUBLIC_* vars are bundled into the client. SENTRY_* (without the
# EXPO_PUBLIC_ prefix) are build-time only, used for source-map upload.

# API base URL — use your machine's LAN IP so a physical device can reach it.
EXPO_PUBLIC_API_URL=http://192.168.1.x:8088

# Disables expo-router's lazy per-route Suspense loading in dev, which avoids
# the "Bundling..." toast spinner appearing near the bottom of the screen on
# cold launch. Costs a slightly slower initial Metro bundle.
EXPO_ROUTER_IMPORT_MODE=sync

# Public R2 bucket URL used to build thumbnail URLs.
EXPO_PUBLIC_R2_PUBLIC_URL=https://<public-bucket>.r2.dev

# --- Google Sign-In ---
# iOS OAuth client ID from Google Cloud Console (also used to derive the
# reversed iOS URL scheme in app.json).
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=your-ios-client-id.apps.googleusercontent.com
# Web OAuth client ID — doubles as google-signin's webClientId, needed on
# both platforms for a consistent ID token.
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=your-web-client-id.apps.googleusercontent.com

# --- Sentry (optional) ---
EXPO_PUBLIC_SENTRY_DSN=https://<key>@<org>.ingest.sentry.io/<project-id>
SENTRY_ORG=your-org
SENTRY_PROJECT=platekeeper
SENTRY_AUTH_TOKEN=your_sentry_auth_token  # build-time source-map upload only
