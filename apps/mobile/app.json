{
  "expo": {
    "name": "Carrot",
    "slug": "mobile",
    "scheme": "carrot",
    "version": "1.0.0",
    "orientation": "portrait",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "icon": "./assets/icon.png",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "cover",
      "backgroundColor": "#cb6134",
      "imageWidth": 437
    },
    "userInterfaceStyle": "light",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.kulesza.carrot",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      },
      "buildNumber": "22",
      "entitlements": {
        "com.apple.security.application-groups": [
          "group.com.kulesza.carrot"
        ]
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#cb6134"
      },
      "predictiveBackGestureEnabled": false,
      "package": "com.kulesza.carrot"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-secure-store",
        {
          "faceIDPermission": false
        }
      ],
      "expo-sharing",
      [
        "expo-image-picker",
        {
          "microphonePermission": false
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#ffffff"
        }
      ],
      "@sentry/react-native",
      [
        "@react-native-google-signin/google-signin",
        {
          "iosUrlScheme": "com.googleusercontent.apps.596430855267-efd23ces8frt74gp7ncpiiiq43ppfss2"
        }
      ],
      [
        "expo-build-properties",
        {
          "ios": {
            "extraPods": [
              {
                "name": "GoogleUtilities",
                "modular_headers": true
              },
              {
                "name": "RecaptchaInterop",
                "modular_headers": true
              },
              {
                "name": "AppCheckCore",
                "modular_headers": true
              }
            ]
          }
        }
      ],
      "expo-image"
    ],
    "extra": {
      "eas": {
        "projectId": "d8507eab-05ed-4623-9f23-1114227f11a8"
      }
    },
    "owner": "xxcuzzme"
  }
}
