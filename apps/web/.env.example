# Web env — Vite (only VITE_-prefixed vars are exposed to the client).
# Copy to .env and fill in real values.

# Dev-server proxy target for /api requests (server-side only — not exposed
# to the client, and NOT prefixed with VITE_ on purpose). The web app always
# calls relative /api/... on its own origin; the vite dev server forwards
# those to this target. Leave unset to use the local API (localhost:8088).
# Set to the production API origin to point local dev at prod instead —
# the browser still only ever talks to localhost:5173, so auth cookies and
# CORS work with no API-side changes.
API_PROXY_TARGET=https://app.carrot.xcxz.xyz

# Public R2 bucket URL used to build image/placeholder URLs.
VITE_R2_PUBLIC_URL=https://<public-bucket>.r2.dev

# Google OAuth Web client ID (Google Cloud Console) — renders the "Continue
# with Google" button and must match the API's GOOGLE_WEB_CLIENT_ID so the
# backend accepts the ID token it issues.
VITE_GOOGLE_CLIENT_ID=your-web-client-id.apps.googleusercontent.com
