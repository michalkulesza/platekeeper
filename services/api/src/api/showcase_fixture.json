    {
      "fixture_id": "6d506c35-5a30-49c0-897d-b48e94add085",
      "title": "Beef Stroganoff",
      "servings": 6,
      "kcal_per_serving": 700,
      "thumbnail_url": "https://www.recipetineats.com/tachyon/2018/01/Beef-Stroganoff_2-1-1.jpg",
      "creator_handle": "recipetineats.com",
      "source_url": "https://www.recipetineats.com/beef-stroganoff/",
      "components": [
        {
          "name": "Beef Stroganoff",
          "yield_note": "",
          "ingredients": [
            "500 g beef sirloin (cut into 1cm wide strips)",
            "2 tbsp olive oil",
            "1 piece onion (finely chopped)",
            "2 clove garlic (minced)",
            "250 g mushrooms (sliced)",
            "1 tbsp butter",
            "2 tbsp flour",
            "500 ml beef broth",
            "150 ml sour cream",
            "1 tbsp Dijon mustard",
            "2 tbsp Worcestershire sauce",
            "null pinch salt (to taste)",
            "null pinch black pepper (to taste)",
            "null bunch fresh parsley (chopped, for garnish)"
          ],
          "steps": [
            "Pat the beef dry with paper towels. Season generously with salt and pepper.",
            "Heat olive oil in a large skillet or Dutch oven over medium-high heat. Add beef in batches and sear until browned on all sides. Remove beef and set aside.",
            "Add onion to the skillet and cook until softened, about 5 minutes. Add garlic and mushrooms and cook for another 5-7 minutes, until mushrooms are browned.",
            "Stir in the butter and flour, cooking for 1 minute until lightly golden.",
            "Gradually whisk in the beef broth, scraping up any browned bits from the bottom of the pan. Bring to a simmer.",
            "Return the beef to the pan. Reduce heat to low, cover and simmer for 1.5 to 2 hours, or until the beef is tender.",
            "Stir in the sour cream, Dijon mustard, and Worcestershire sauce. Heat through gently but do not boil.",
            "Season with salt and pepper to taste. Garnish with fresh parsley before serving."
          ],
