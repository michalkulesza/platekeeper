# API env — read by services/api (src/api/config.py) when run directly
# (e.g. `uvicorn`). In docker compose the root .env is used instead.
# Copy to .env and fill in real values.

# --- Required ---
SCRAPECREATORS_API_KEY=your_key_here
GEMINI_API_KEY=your_key_here

# --- Optional (sensible defaults in config.py) ---
ALLOWED_ORIGINS=http://localhost:5173
DATABASE_URL=postgresql+asyncpg://platekeeper:platekeeper@localhost:5432/platekeeper
SECRET=your_secret_here  # openssl rand -hex 32

# --- Email (Resend — optional; console fallback logs codes when unset) ---
RESEND_API_KEY=          # Resend API key (re_...)
EMAIL_FROM=              # e.g. PlateKeeper <no-reply@yourdomain.com>

# --- R2 image storage (optional — uploads skipped when unset) ---
R2_ENDPOINT_URL=https://<account-id>.r2.cloudflarestorage.com
R2_ACCESS_KEY_ID=your_access_key_id
R2_SECRET_ACCESS_KEY=your_secret_access_key
R2_BUCKET_NAME=platekeeper-images
R2_PUBLIC_URL=https://<public-bucket>.r2.dev

# --- APNs push notifications (optional — pushes skipped when unset) ---
APNS_KEY_P8=           # Contents of the .p8 file (PEM)
APNS_KEY_ID=           # 10-char key ID from Apple Developer
APNS_TEAM_ID=          # 10-char team ID
APNS_BUNDLE_ID=com.kulesza.platekeeper
APNS_SANDBOX=true      # false for production

# --- Google Sign-In — OAuth client IDs from Google Cloud Console ---
GOOGLE_IOS_CLIENT_ID=
GOOGLE_ANDROID_CLIENT_ID=
GOOGLE_WEB_CLIENT_ID=

# --- Debug (local dev only — never set in production) ---
DEBUG_FORCE_HIGH_DEMAND=false  # true forces the background-import "high demand" alert on the first Gemini call
